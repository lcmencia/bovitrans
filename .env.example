# =============================================================================
# BoviTrans MVP — Variables de entorno (US-7.1)
# Copiar a .env y ajustar:  cp .env.example .env
# =============================================================================

# --- Base de datos (servicio db) ---
POSTGRES_USER=bovitrans
POSTGRES_PASSWORD=bovitrans
POSTGRES_DB=bovitrans
DB_PORT=5432

# --- Aplicación (servicio app) ---
APP_PORT=3000

# Conexión usada por la app. En docker-compose el host es "db" (nombre del servicio).
# Para correr la app fuera de Docker contra la DB del contenedor, usar localhost.
DATABASE_URL=postgres://bovitrans:bovitrans@db:5432/bovitrans

# Secreto para firmar las sesiones/JWT (CAMBIAR en cualquier entorno real)
JWT_SECRET=dev-secret-change-me

# Marca la cookie de sesión como Secure (solo HTTPS). Dejar en false para
# pruebas locales por http://localhost; poner true en un deploy con HTTPS.
COOKIE_SECURE=false
