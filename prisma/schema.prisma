// schema.prisma — BoviTrans
//
// IMPORTANTE (ADR-009): la fuente de verdad del esquema es db/init.sql.
// Este archivo refleja ese esquema para generar el Prisma Client tipado.
// No se usa `prisma migrate`. Para re-sincronizar tras cambiar init.sql:
//   docker-compose up -d db   # crea el esquema desde init.sql
//   npx prisma db pull        # introspección -> regenera estos modelos
//   npx prisma generate       # regenera el client
//
// Nota: el índice parcial único `uniq_camion_activo` (ADR-004) vive solo en
// init.sql; Prisma no modela índices parciales y la DB es quien lo garantiza.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum rol_usuario {
  cliente
  operador
}

enum estado_solicitud {
  PENDIENTE
  ASIGNADA
  EN_TRANSITO
  COMPLETADA
  CANCELADA
}

model usuarios {
  id            BigInt      @id @default(autoincrement())
  nombre        String
  email         String      @unique
  password_hash String
  rol           rol_usuario
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime    @default(now()) @db.Timestamptz(6)

  solicitudes_cliente  solicitudes[] @relation("cliente")
  solicitudes_operador solicitudes[] @relation("operador")
}

model camiones {
  id           BigInt   @id @default(autoincrement())
  patente      String   @unique
  capacidad    Int
  consumo_l_km Decimal  @db.Decimal(8, 4)
  activo       Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)

  solicitudes solicitudes[]
}

model configuracion {
  id                       Int      @id
  precio_combustible_litro Decimal  @db.Decimal(10, 2)
  updated_at               DateTime @default(now()) @db.Timestamptz(6)
}

model solicitudes {
  id                 BigInt           @id @default(autoincrement())
  cliente_id         BigInt
  operador_id        BigInt?
  camion_id          BigInt?
  solicitante_nombre String
  cabezas            Int

  origen_lat    Decimal @db.Decimal(9, 6)
  origen_lng    Decimal @db.Decimal(9, 6)
  origen_label  String?
  destino_lat   Decimal @db.Decimal(9, 6)
  destino_lng   Decimal @db.Decimal(9, 6)
  destino_label String?

  estado estado_solicitud @default(PENDIENTE)

  distancia_km       Decimal?  @db.Decimal(10, 2)
  consumo_usado      Decimal?  @db.Decimal(8, 4)
  precio_litro_usado Decimal?  @db.Decimal(10, 2)
  costo_por_viaje    Decimal?  @db.Decimal(12, 2)
  nro_viajes         Int?
  costo_total        Decimal?  @db.Decimal(14, 2)
  asignada_at        DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  cliente  usuarios  @relation("cliente", fields: [cliente_id], references: [id])
  operador usuarios? @relation("operador", fields: [operador_id], references: [id])
  camion   camiones? @relation(fields: [camion_id], references: [id])
  tracking tracking_points[]

  @@index([estado])
  @@index([cliente_id])
  @@index([camion_id])
}

model tracking_points {
  id            BigInt      @id @default(autoincrement())
  solicitud_id  BigInt
  lat           Decimal     @db.Decimal(9, 6)
  lng           Decimal     @db.Decimal(9, 6)
  velocidad_kmh Decimal?    @db.Decimal(6, 2)
  registrado_en DateTime    @default(now()) @db.Timestamptz(6)

  solicitud solicitudes @relation(fields: [solicitud_id], references: [id], onDelete: Cascade)

  @@index([solicitud_id, registrado_en])
}
